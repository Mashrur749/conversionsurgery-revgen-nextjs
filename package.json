{
  "name": "conversionsurgery-revgen-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prepare": "husky",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "cf:build": "npx @opennextjs/cloudflare build",
    "cf:dev": "npx wrangler dev",
    "cf:deploy": "npx @opennextjs/cloudflare build && npx wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "db:seed": "npx tsx scripts/seed.ts",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "db:reset": "npx drizzle-kit drop && npm run db:setup",
    "ms:check:line-limits": "./scripts/specs/check-ms-line-limits.sh",
    "ms:check:gap-map": "./scripts/specs/check-ms-gap-map.sh",
    "ms:check:spec-structure": "./scripts/specs/check-ms-spec-structure.sh",
    "ms:check:no-legacy-spec-refs": "./scripts/specs/check-no-legacy-spec-refs.sh",
    "ms:gate": "./scripts/specs/ms-quality-gate.sh",
    "ms:gate:build": "./scripts/specs/ms-quality-gate.sh --with-build",
    "ms:gate:full": "./scripts/specs/ms-quality-gate.sh --with-build --with-tests",
    "quality:runtime-smoke": "./scripts/quality/runtime-smoke.sh",
    "quality:no-regressions": "./scripts/quality/no-regressions.sh",
    "quality:feature-sweep": "./scripts/quality/feature-sweep.sh",
    "quality:logging-guard": "./scripts/quality/logging-guard.sh",
    "quality:install-pre-commit-hook": "./scripts/quality/install-pre-commit-hook.sh",
    "quality:install-pre-push-hook": "./scripts/quality/install-pre-push-hook.sh",
    "quality:install-agent-hooks": "./scripts/quality/install-agent-hooks.sh",
    "ops:replay": "./scripts/ops/replay.sh",
    "ops:replay:core": "./scripts/ops/replay.sh all-core",
    "ops:drill:export": "npx tsx scripts/ops/export-recovery-drill.ts",
    "docmost:sync": "node scripts/docmost-sync/sync-docmost.mjs",
    "docmost:sync:local": "node scripts/docmost-sync/sync-docmost.mjs",
    "docmost:sync:dry": "DOCMOST_DRY_RUN=1 node scripts/docmost-sync/sync-docmost.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ai": "vitest run --config vitest.ai.config.ts",
    "test:ai:visual": "npx tsx scripts/test/run-ai-scenarios.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@auth/drizzle-adapter": "^1.11.1",
    "@aws-sdk/client-s3": "^3.985.0",
    "@aws-sdk/s3-request-presigner": "^3.985.0",
    "@langchain/core": "^1.1.20",
    "@langchain/langgraph": "^1.1.4",
    "@neondatabase/serverless": "^1.0.2",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.1",
    "googleapis": "^171.4.0",
    "libphonenumber-js": "^1.12.36",
    "lucide-react": "^0.563.0",
    "next": "16.1.5",
    "next-auth": "^5.0.0-beta.30",
    "radix-ui": "^1.4.3",
    "react": "19.1.5",
    "react-dom": "19.1.5",
    "recharts": "^3.7.0",
    "resend": "^6.9.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.4.0",
    "twilio": "^5.12.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@opennextjs/cloudflare": "^1.16.3",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.31",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.2.4",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "husky": "^9.1.7",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.4",
    "vitest": "^4.0.18",
    "wrangler": "^4.63.0"
  }
}
